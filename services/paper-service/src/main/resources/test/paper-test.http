@url = http://localhost:8080/paper-service/papers

### Get paper details
@id = YjNjZGU2YTUtYWYyYi00ZDJjLTljYWYtN2UxODY3ZDY3OWI4
GET {{url}}/details?id={{id}}
Accept: application/json


### Get references
GET {{url}}/references?id={{id}}
Accept: application/json

### Parse citations
POST {{url}}/pdf/parse
Content-Type: multipart/form-data; boundary=WebAppBoundary
Accept: application/json

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="Phishing_Emails_Detection_in_Cyber_Security.pdf"
Content-Type: application/pdf

< ./Phishing_Emails_Detection_in_Cyber_Security.pdf
--WebAppBoundary--

### Upload pdf metadata with happy case
POST {{url}}/pdf/upload
Content-Type: application/json
Accept: application/json

{
  "dataUrl": "http://localhost:8080/hehe",
  "description": "description",
  "keywords": [
    "kw1", "kw2", "kw3"
  ],
  "title": "title1",
  "authors": "Author1, author 2",
  "journal": "Journal",
  "publicationYear": 2021,
  "doi": "10.34190/iccws.20.1.3366"
}

### Upload pdf metadata with wrong format doi case
POST {{url}}/pdf/upload
Content-Type: application/json
Accept: application/json

{
  "dataUrl": "http://localhost:8080/hehe",
  "description": "description",
  "keywords": [
    "kw1", "kw2", "kw3"
  ],
  "title": "title1",
  "authors": "Author1, author 2",
  "journal": "Journal",
  "publicationYear": 2021,
  "doi": "10.3419ccws.20.1.3366"
}

### Upload pdf metadata with wrong format uri case
POST {{url}}/pdf/upload
Content-Type: application/json
Accept: application/json

{
  "dataUrl": "http://ocal:8/hhe",
  "description": "description",
  "keywords": [
    "kw1", "kw2", "kw3"
  ],
  "title": "title1",
  "authors": "Author1, author 2",
  "journal": "Journal",
  "publicationYear": 2021,
  "doi": "10.34190/iccws.20.1.3369"
}

### Ping api
HEAD {{url}}/health

### Get all papers - No search query
GET {{url}}/all?index=0&size=10
Accept: application/json

### Get all papers - With search query
GET {{url}}/all?search=machine learning&index=0&size=10
Accept: application/json

### Get all papers - Search by title
GET {{url}}/all?search=Phishing&index=0&size=10
Accept: application/json

### Get all papers - Search by authors
GET {{url}}/all?search=Author1&index=0&size=10

### Get paper with pagination and full of request params
GET {{url}}/all?index=1&size=&author=Hoan&journal=hehe&from=2004&to=2025
Accept: application/json

### Get all papers - Search by journal
GET {{url}}/all?search=Journal&index=0&size=10
### Get paper with pagination and missing some request params #1

GET {{url}}/all?index=1&size=&from=2004&to=2025
Accept: application/json

### Get all papers - Pagination
GET {{url}}/all?index=1&size=5
### Get paper with pagination and missing some request params #2
GET {{url}}/all?index=1&author=Hoan&journal=hehe
Accept: application/json

### Get all papers - Search by tags (single tag)
GET {{url}}/all?tagIds=e5507c1e-e431-4f16-b5d4-bd11138e1963&index=0&size=10
Accept: application/json

### Get all papers - Search by multiple tags
GET {{url}}/all?tagIds=e5507c1e-e431-4f16-b5d4-bd11138e1963&tagIds=53e497b0-9ec7-4ebc-9ade-56f4d3e7be67&index=0&size=10
Accept: application/json

### Get all papers - Search by tags with search query
GET {{url}}/all?tagIds=e5507c1e-e431-4f16-b5d4-bd11138e1963&search=machine learning&index=0&size=10
Accept: application/json