@baseUrl = http://localhost:8080/v1/api/reading-service

# ===========================================
# QUICK TEST - Progress Tracking API
# File này dùng để test nhanh với dữ liệu mẫu
# ===========================================

# THAY CÁC GIÁ TRỊ SAU BẰNG IDs THỰC TẾ CỦA BẠN:
@collectionId = YjNjZGU2YTUtYWYyYi00ZDJjLTljYWYtN2UxODY3ZDY3OWI4
@paperId = YWJjZGVmZ2hpams=
@userId = dXNlcjEyMzQ1Njc4

# ===========================================
# TEST 1: Tạo workflow để có dữ liệu test
# ===========================================

### Create Workflow
POST {{baseUrl}}/workflows
Content-Type: application/json

{
  "collectionId": "{{collectionId}}",
  "paperId": "{{paperId}}",
  "usersid": "{{userId}}"
}

### Update Progress
PUT {{baseUrl}}/workflows/progress
Content-Type: application/json

{
  "collectionId": "{{collectionId}}",
  "paperId": "{{paperId}}",
  "usersid": "{{userId}}",
  "lastPage": 20,
  "progress": 50
}

### Update Status
PATCH {{baseUrl}}/workflows/status
Content-Type: application/json

{
  "collectionId": "{{collectionId}}",
  "paperId": "{{paperId}}",
  "usersid": "{{userId}}",
  "status": "reading"
}

# ===========================================
# TEST 2: Progress Tracking APIs
# ===========================================

### Get Collection Dashboard (Main endpoint for PI)
GET {{baseUrl}}/progress/collection/{{collectionId}}
Accept: application/json

### Get Team Member Progress
GET {{baseUrl}}/progress/collection/{{collectionId}}/member/{{userId}}
Accept: application/json

### Get Paper Progress
GET {{baseUrl}}/progress/collection/{{collectionId}}/paper/{{paperId}}
Accept: application/json

### Get All Workflows by Collection
GET {{baseUrl}}/workflows/collection/{{collectionId}}
Accept: application/json

### Get Workflows by Collection - Filter: reading
GET {{baseUrl}}/workflows/collection/{{collectionId}}?status=reading
Accept: application/json

















