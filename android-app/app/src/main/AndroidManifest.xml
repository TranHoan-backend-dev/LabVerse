<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_DOCUMENTS"
        android:minSdkVersion="33" />

    <application
        android:name=".LabVerseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LabVerse"
        android:usesCleartextTraffic="true"
        tools:replace="android:fullBackupContent">
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".presentation.auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".presentation.auth.RegisterActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.user.UserActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.paper.PaperDetailsActivity"
            android:exported="true"
            tools:targetApi="34" />
        <activity
            android:name=".presentation.paper.PDFReaderActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".presentation.paper.ImportPaperByBibtexActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.paper.ImportPaperManuallyActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.feed.FeedActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.search.SearchActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.profile.ProfileActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.feed.FilterActivity"
            android:exported="true"
            tools:targetApi="34" />
        <activity
            android:name=".presentation.team.TeamCreateActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.team.TeamListActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.team.TeamDetailActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.team.TeamEditActivity"
            android:exported="false"
            android:parentActivityName=".presentation.team.TeamDetailActivity" />
        <activity
            android:name=".presentation.collection.CollectionDetailsActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.collection.SelectPaperActivity"
            android:exported="false"
            android:parentActivityName=".presentation.collection.CollectionDetailsActivity" />
        <activity
            android:name=".presentation.collection.CollectionsActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.collection.CollectionMembersActivity"
            android:exported="false"
            android:parentActivityName=".presentation.collection.CollectionsActivity" />
        <activity
            android:name=".presentation.readinglist.ReadingListsActivity"
            android:exported="true" />
        <activity
            android:name=".presentation.readinglist.ReadingListDetailActivity"
            android:exported="false"
            android:parentActivityName=".presentation.readinglist.ReadingListsActivity" />
        <activity
            android:name=".presentation.readinglist.SelectPaperForReadingListActivity"
            android:exported="false"
            android:parentActivityName=".presentation.readinglist.ReadingListDetailActivity" />
        <activity
            android:name=".presentation.notification.NotificationListActivity"
            android:exported="true" />
    </application>

</manifest>