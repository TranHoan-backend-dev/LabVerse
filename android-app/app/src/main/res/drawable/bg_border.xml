<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Viền trên -->
    <item
        android:height="1dp"
        android:gravity="top">
        <shape>
            <solid android:color="#E0E0E0" />
        </shape>
    </item>

    <!-- Nền trắng -->
    <item>
        <shape>
            <solid android:color="@color/white" />
        </shape>
    </item>

    <!-- Viền dưới -->
    <item
        android:height="1dp"
        android:gravity="bottom">
        <shape>
            <solid android:color="#E0E0E0" />
        </shape>
    </item>

</layer-list>
