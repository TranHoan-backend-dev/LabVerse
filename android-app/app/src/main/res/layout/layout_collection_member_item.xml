<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/image_member_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:contentDescription="Member avatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Member Name -->
        <TextView
            android:id="@+id/text_member_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Member Name"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/image_member_avatar"
            app:layout_constraintStart_toEndOf="@id/image_member_avatar"
            app:layout_constraintEnd_toStartOf="@id/chip_access_level" />

        <!-- Access Level Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_access_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUTHOR"
            style="@style/Widget.Material3.Chip.Assist"
            app:chipMinHeight="24dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/text_member_name"
            app:layout_constraintStart_toEndOf="@id/text_member_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Member Email/ID -->
        <TextView
            android:id="@+id/text_member_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/text_member_name"
            app:layout_constraintStart_toStartOf="@id/text_member_name"
            app:layout_constraintEnd_toStartOf="@id/button_change_access" />

        <!-- Change Access Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_change_access"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change"
            style="@style/Widget.Material3.Button.TextButton"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toTopOf="@id/text_member_email"
            app:layout_constraintStart_toEndOf="@id/text_member_email"
            app:layout_constraintEnd_toStartOf="@id/button_remove_member" />

        <!-- Remove Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_remove_member"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remove"
            style="@style/Widget.Material3.Button.TextButton"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorError"
            android:layout_marginStart="4dp"
            android:minWidth="0dp"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toTopOf="@id/text_member_email"
            app:layout_constraintStart_toEndOf="@id/button_change_access"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

