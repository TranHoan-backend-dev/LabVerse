<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Active Collection Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_active_collection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/blue"
        app:cardElevation="4dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.MediumComponent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_active"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                app:chipBackgroundColor="#6589DC"
                android:textColor="@color/white"
                app:chipMinHeight="24dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/button_active_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_more_vert_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/text_active_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Collection Name"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/chip_active"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/button_active_options" />

            <TextView
                android:id="@+id/text_active_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 papers • 0 members"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnPrimary"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/text_active_title"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/text_active_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recently updated"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnPrimary"
                app:layout_constraintTop_toBottomOf="@id/text_active_info"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- RecyclerView for Collections -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_collections"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_active_collection"
        app:layout_constraintBottom_toTopOf="@id/button_create_collection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/text_empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No collections yet. Create your first collection!"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Create Collection Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_create_collection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Create New Collection"
        app:iconGravity="textStart"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        style="@style/Widget.Material3.Button"
        app:backgroundTint="#5780D9"
        app:layout_constraintTop_toBottomOf="@id/recycler_collections"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Invite Team Members Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_invite_members"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Invite Team Members"
        app:icon="@drawable/ic_people_24"
        app:iconGravity="textStart"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:layout_constraintTop_toBottomOf="@id/button_create_collection"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>


