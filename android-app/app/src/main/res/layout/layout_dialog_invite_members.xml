<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Collection Selection (only show if collection is null) -->
    <TextView
        android:id="@+id/text_collection_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Collection"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <Spinner
        android:id="@+id/spinner_collection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@drawable/bg_edit_text_outline"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Member Email"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/edit_member_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter email address"
        android:inputType="textEmailAddress"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@drawable/bg_edit_text_outline"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Access Level"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinner_access_level"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@drawable/bg_edit_text_outline" />
</LinearLayout>


