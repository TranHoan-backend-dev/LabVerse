<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Chip "New" -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_chip_green"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="@string/new_title"
        android:textColor="@color/white"
        android:textSize="12sp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Deep Learning Approaches for Protein Structure Prediction: A Comprehensive Review"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Description -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="This paper presents a comprehensive analysis of recent deep learning methodologies."
        android:textColor="#666"
        android:textSize="13sp" />

    <!-- Meta info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="Nature Biotechnology · 2 days ago · 15 citations"
        android:textColor="#888"
        android:textSize="12sp" />

    <!-- Footer: author, button, share icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Author section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_crop"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@mipmap/avt_mock_round" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                style="?attr/materialIconButtonStyle"
                android:layout_width="50dp"
                android:layout_height="25dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/white"
                app:icon="@drawable/ic_share"
                app:iconSize="40dp"
                app:iconTint="@color/black" />

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/dark_blue"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:text="@string/read"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:cornerRadius="6dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
