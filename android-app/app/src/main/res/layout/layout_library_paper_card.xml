<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/paper_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Status Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unread"
                android:textSize="10sp"
                android:textColor="@color/blue_400"
                app:chipBackgroundColor="@color/blue_50"
                app:chipMinHeight="24dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Paper Title -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Deep Learning Approaches for Protein Structure Prediction"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Meta Info -->
        <TextView
            android:id="@+id/text_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Nature Biotechnology • 2024 • Authors: Chen, L., Wang, K., Smith, J."
            android:textSize="12sp"
            android:textColor="@color/gray_500"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- PDF, Reads, Citations Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_pdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄 PDF"
                android:textSize="11sp"
                android:textColor="@color/gray_500" />

            <TextView
                android:id="@+id/text_read"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="👁 2.3k reads"
                android:textSize="11sp"
                android:textColor="@color/gray_500" />

            <TextView
                android:id="@+id/text_citations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="📚 127 citations"
                android:textSize="11sp"
                android:textColor="@color/gray_500" />
        </LinearLayout>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_start_reading"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Start Reading"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/blue_400"
                app:cornerRadius="6dp" />

            <Button
                android:id="@+id/btn_review_notes"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Review Notes"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/yellow"
                android:visibility="gone"
                app:cornerRadius="6dp" />

            <ImageButton
                android:id="@+id/btn_bookmark"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_bookmark"
                android:contentDescription="@string/favorites"
                app:tint="@color/gray_500" />

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                android:contentDescription="@string/share"
                app:tint="@color/gray_500" />
        </LinearLayout>

        <!-- Progress Bar (only visible when reading) - at the bottom -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="45"
            android:progressTint="@color/third_green"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
