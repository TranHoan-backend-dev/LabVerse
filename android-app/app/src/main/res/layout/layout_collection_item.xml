<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_collection_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Collection Name"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chip_collection_role" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_collection_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Owner"
            style="@style/Widget.Material3.Chip.Assist"
            app:chipBackgroundColor="#7CCA97"
            android:textColor="#1B5E20"
            app:chipMinHeight="24dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/text_collection_title"
            app:layout_constraintBottom_toBottomOf="@id/text_collection_title"
            app:layout_constraintStart_toEndOf="@id/text_collection_title"
            app:layout_constraintEnd_toStartOf="@id/button_collection_options" />

        <ImageView
            android:id="@+id/button_collection_options"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_more_vert_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="@id/text_collection_title"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="@string/collection_options" />

        <TextView
            android:id="@+id/text_collection_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 papers • 0 members"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/text_collection_title"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layout_creator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/text_collection_info"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/image_creator_avatar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_circle_crop"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@mipmap/avt_mock_round"
                android:contentDescription="@string/user_avatar" />

            <TextView
                android:id="@+id/text_creator_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Creator Name"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>


