<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_card"
    android:layout_marginBottom="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trending"
        android:background="@drawable/bg_chip_orange"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quantum Computing Applications in Drug Discovery: Current State and Future Prospects"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="An extensive review of quantum computing methodologies being applied to accelerate drug discovery."
        android:textColor="#666"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Science · 1 week ago · 42 citations"
        android:textColor="#888"
        android:textSize="12sp" />
</LinearLayout>
